
<div class="curtain-container" id="curtain">
  <div class="curtain-panel left"></div>
  <div class="curtain-panel right"></div>
</div>

<style>
  .curtain-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 1000;
    pointer-events: none;
    animation: fade-out 1.5s 4.5s forwards;
  }

  .curtain-panel {
    position: absolute;
    top: 0;
    height: 100vh;
    width: 50vw;
    background: linear-gradient(to right, #610C04, #A52A2A, #610C04);
    box-shadow: 0 0 30px rgba(0, 0, 0, 0.7);
  }

  .curtain-panel::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 30px;
    background: 
      radial-gradient(circle at 10px -5px, transparent 15px, #610C04 15px, #610C04 20px, transparent 21px),
      radial-gradient(circle at 30px 10px, transparent 15px, #8B0000 15px, #8B0000 20px, transparent 21px);
    background-size: 40px 40px;
    background-repeat: repeat-x;
    z-index: 2;
  }

  .curtain-panel.left {
    left: 0;
    animation: open-left 4s 1s forwards cubic-bezier(0.86, 0, 0.07, 1);
  }

  .curtain-panel.right {
    right: 0;
    animation: open-right 4s 1s forwards cubic-bezier(0.86, 0, 0.07, 1);
  }

  @keyframes open-left {
    0% {
      clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%);
    }
    100% {
      clip-path: polygon(0% 0%, 20% 0%, 5% 100%, 0% 100%);
    }
  }

  @keyframes open-right {
    0% {
      clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%);
    }
    100% {
      clip-path: polygon(80% 0%, 100% 0%, 100% 100%, 95% 100%);
    }
  }

  @keyframes fade-out {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
      visibility: hidden;
    }
  }
</style>
