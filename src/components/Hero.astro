---
import BarberPole from './BarberPole.astro';
---

<section class="relative h-screen flex items-center justify-center text-center">
    <div class="absolute inset-0 bg-ivory opacity-50"></div>
    <div class="relative z-10">
        <div class="flex items-center justify-center">
            <BarberPole />
            <div class="ml-8">
                <h1 class="text-6xl font-bold text-gunmetal">Your Hair, Reimagined.</h1>
                <p class="text-2xl text-fiery-terracotta mt-4">Relax. Renew. Refine.</p>
                <p class="text-lg text-gunmetal mt-2">Define Your Look with Our Experts.</p>
            </div>
        </div>
    </div>
</section>
