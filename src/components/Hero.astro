---
import BarberPole from './BarberPole.astro';
---

<section class="relative h-screen flex items-center justify-center text-center">
    <div class="absolute inset-0 bg-ivory opacity-50"></div>
    <div class="relative z-10 px-4">
        <div class="flex flex-col sm:flex-row items-center justify-center">
            <BarberPole />
            <div class="mt-8 sm:mt-0 sm:ml-8">
                <h1 class="text-4xl sm:text-6xl font-bold text-gunmetal">Your Hair, Reimagined.</h1>
                <p class="text-xl sm:text-2xl text-fiery-terracotta mt-4">Relax. Renew. Refine.</p>
                <p class="text-md sm:text-lg text-gunmetal mt-2">Define Your Look with Our Experts.</p>
            </div>
        </div>
    </div>
</section>
