---
import '../styles/HairAnimation.css';
const numBunches = 100;
---

<div class="hair-fall-container" aria-hidden="true">
  {Array.from({ length: numBunches }).map(() => {
    const height = 70 + Math.random() * 100;
    const width = 15 + Math.random() * 10;
    const style = `
      --rotation: ${(Math.random() - 0.5) * 60}deg;
      left: ${Math.random() * 100}%;
      animation-delay: ${Math.random() * 3.5}s;
      animation-duration: ${2 + Math.random() * 3}s;
      width: ${width}px;
      height: ${height}px;
    `;

    const cx = width / 2 + (Math.random() - 0.5) * width;
    const cy = height / 2;
    const pathD = `M ${width / 2},0 Q ${cx},${cy} ${width / 2},${height}`;

    const strokeWidth = 2 + Math.random() * 3;
    const hairColor = `hsl(30, 30%, ${10 + Math.random() * 15}%)`;

    return (
      <div class="hair-bunch" style={style}>
        <svg width="100%" height="100%" viewBox={`0 0 ${width} ${height}`} preserveAspectRatio="none">
          <path d={pathD} fill="none" stroke={hairColor} stroke-width={strokeWidth} stroke-linecap="round" />
        </svg>
      </div>
    );
  })}
</div>

<script src="../scripts/hair-animation.js"></script>
