---
// src/components/ContactForm.astro
---
<div class="w-full max-w-4xl mx-auto bg-white p-8 md:p-12 rounded-2xl shadow-2xl border border-gray-200">
  <h3 class="text-3xl font-extrabold mb-2 text-center" style="color: var(--gunmetal);">Schedule Your Visit</h3>
  <p class="text-center mb-8 text-gray-500 font-light">Fill out the form below and we'll contact you to confirm.</p>
  
  <form action="#" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6">
    
    <!-- Name -->
    <div class="md:col-span-1">
      <label for="full-name" class="block text-sm font-bold mb-2" style="color: var(--gunmetal);">Full Name</label>
      <input type="text" id="full-name" name="full-name" required 
             class="w-full p-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-fiery-terracotta focus:border-transparent transition">
    </div>
    
    <!-- Email -->
    <div class="md:col-span-1">
      <label for="email" class="block text-sm font-bold mb-2" style="color: var(--gunmetal);">Email Address</label>
      <input type="email" id="email" name="email" required
             class="w-full p-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-fiery-terracotta focus:border-transparent transition">
    </div>

    <!-- Phone Number -->
    <div class="md:col-span-1">
      <label for="phone" class="block text-sm font-bold mb-2" style="color: var(--gunmetal);">Phone Number</label>
      <input type="tel" id="phone" name="phone" required
             class="w-full p-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-fiery-terracotta focus:border-transparent transition">
    </div>

    <!-- Desired Service -->
    <div class="md:col-span-1">
      <label for="service" class="block text-sm font-bold mb-2" style="color: var(--gunmetal);">Desired Service(s)</label>
      <input type="text" id="service" name="service" placeholder="e.g., Precision Cut, Color Treatment"
             class="w-full p-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-fiery-terracotta focus:border-transparent transition">
    </div>

    <!-- Preferred Date/Time -->
    <div class="md:col-span-2">
      <label for="datetime" class="block text-sm font-bold mb-2" style="color: var(--gunmetal);">Preferred Date & Time</label>
      <input type="text" id="datetime" name="datetime" placeholder="e.g., Weekday afternoons, this Saturday morning"
             class="w-full p-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-fiery-terracotta focus:border-transparent transition">
    </div>
    
    <!-- Message -->
    <div class="md:col-span-2">
      <label for="message" class="block text-sm font-bold mb-2" style="color: var(--gunmetal);">Additional Notes (Optional)</label>
      <textarea id="message" name="message" rows="4"
                class="w-full p-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-fiery-terracotta focus:border-transparent transition"></textarea>
    </div>
    
    <!-- Submit Button -->
    <div class="md:col-span-2 text-center mt-4">
      <button type="submit" 
              class="w-full md:w-auto text-white font-bold py-4 px-12 rounded-lg transition-transform transform hover:scale-105 shadow-lg text-lg"
              style="background-color: var(--fiery-terracotta);">
        Send Request
      </button>
    </div>

  </form>
</div>
