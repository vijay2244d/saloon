---
// src/components/Header.astro
---
<header class="w-full p-4 md:p-6 shadow-md" style="background-color: var(--ivory);">
  <div class="container mx-auto flex justify-between items-center">
    <a href="/" class="text-2xl font-bold" style="color: var(--gunmetal);">The Smart Salon</a>
    
    <!-- Hamburger Menu Button -->
    <div class="md:hidden">
      <button id="menu-btn" class="text-gunmetal focus:outline-none">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
        </svg>
      </button>
    </div>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center">
      <ul class="flex space-x-6 md:space-x-8">
        <li><a href="/about" class="nav-link">About</a></li>
        <li><a href="/services" class="nav-link">Services</a></li>
        <li><a href="/offers" class="nav-link">Offers</a></li>
        <li><a href="/reviews" class="nav-link">Reviews</a></li>
      </ul>
      <a href="/booking" class="ml-8 text-white font-bold py-3 px-8 rounded-lg transition-all transform hover:scale-105 shadow-lg cta-button">
        Book Now
      </a>
    </nav>
  </div>

  <!-- Mobile Navigation Menu -->
  <div id="menu" class="hidden md:hidden mt-4">
    <ul class="flex flex-col space-y-4">
      <li><a href="/about" class="nav-link-mobile">About</a></li>
      <li><a href="/services" class="nav-link-mobile">Services</a></li>
      <li><a href="/offers" class="nav-link-mobile">Offers</a></li>
      <li><a href="/reviews" class="nav-link-mobile">Reviews</a></li>
      <li>
        <a href="/booking" class="block mt-4 text-white text-center font-bold py-3 px-8 rounded-lg transition-all transform hover:scale-105 shadow-lg cta-button">
          Book Now
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('menu');

  btn.addEventListener('click', () => {
    menu.classList.toggle('hidden');
  });
</script>

<style>
  .nav-link {
    position: relative;
    color: var(--gunmetal);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .nav-link:hover {
    color: var(--fiery-terracotta);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -5px;
    left: 50%;
    background-color: var(--fiery-terracotta);
    transition: all 0.3s ease;
    transform: translateX(-50%);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link-mobile {
    display: block;
    padding: 0.5rem 0;
    color: var(--gunmetal);
    text-decoration: none;
    transition: color 0.3s ease;
    font-size: 1.1rem;
    text-align: center;
  }

  .nav-link-mobile:hover {
    color: var(--fiery-terracotta);
  }

  /* New CTA Button Style */
  .cta-button {
    background-color: var(--fiery-terracotta);
    box-shadow: 
      0 0 15px rgba(205, 87, 66, 0.6), /* Inner glow */
      0 10px 20px rgba(0, 0, 0, 0.2);   /* Deeper shadow */
  }

  .cta-button:hover {
    box-shadow: 
      0 0 25px rgba(205, 87, 66, 0.8),
      0 15px 30px rgba(0, 0, 0, 0.3);
  }
</style>