---
---
<header class="w-full p-4 md:p-6 shadow-md" style="background-color: var(--ivory);">
  <div class="container mx-auto flex justify-between items-center">
    <a href="/" class="text-2xl font-bold" style="color: var(--gunmetal);">The Smart Salon</a>
    <nav>
      <ul class="flex space-x-8 md:space-x-10">
        <li><a href="/" class="nav-link">Home</a></li>
        <li><a href="/about" class="nav-link">About</a></li>
        <li><a href="/services" class="nav-link">Services</a></li>
        <li><a href="/contact" class="nav-link">Contact</a></li>
        <li><a href="/reviews" class="nav-link">Reviews</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .nav-link {
    position: relative;
    color: var(--gunmetal);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .nav-link:hover {
    color: var(--fiery-terracotta);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -5px;
    left: 50%;
    background-color: var(--fiery-terracotta);
    transition: all 0.3s ease;
    transform: translateX(-50%);
  }

  .nav-link:hover::after {
    width: 100%;
  }
</style>
