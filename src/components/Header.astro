---
const { active } = Astro.props;
---

<header>
  <div class="logo">
    <a href="/">The Smart Salon</a>
  </div>
  <nav>
    <a href="/" class={active === '/' ? 'active' : ''}>Home</a>
    <a href="/about" class={active === '/about' ? 'active' : ''}>About</a>
    <a href="/services" class={active === '/services' ? 'active' : ''}>Services</a>
    <a href="/offers" class={active === '/offers' ? 'active' : ''}>Offers</a>
    <a href="/book" class={active === '/book' ? 'active' : ''}>Book</a>
  </nav>
</header>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  nav {
    display: flex;
    gap: 1rem; /* Adjust gap for closer spacing */
  }
</style>