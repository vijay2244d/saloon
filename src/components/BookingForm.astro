---
import '../styles/BookingForm.css';
---
<div class="w-full max-w-4xl mx-auto bg-white p-8 md:p-12 rounded-2xl shadow-2xl border border-gray-200">
  <h3 class="text-3xl font-extrabold mb-2 text-center booking-form-h3">Schedule Your Visit</h3>
  <p class="text-center mb-8 text-gray-500 font-light">Complete the fields below to book your appointment.</p>
  
  <!-- The Form -->
  <form action="#" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
    <!-- Left Column: Date/Time Inputs -->
    <div class="space-y-6">
      <div>
        <label for="date-display" class="block text-sm font-bold mb-2 booking-form-label">Date</label>
        <input type="text" id="date-display" readonly placeholder="Click to choose a date" class="w-full p-3 rounded-lg border border-gray-300 cursor-pointer focus:ring-2 focus:ring-fiery-terracotta focus:border-transparent transition bg-gray-50" aria-label="Selected date">
      </div>
      <div>
        <label for="time-display" class="block text-sm font-bold mb-2 booking-form-label">Time</label>
        <input type="text" id="time-display" readonly placeholder="Click to choose a time" class="w-full p-3 rounded-lg border border-gray-300 cursor-pointer focus:ring-2 focus:ring-fiery-terracotta focus:border-transparent transition bg-gray-50" aria-label="Selected time">
      </div>
    </div>

    <!-- Right Column: Personal Info -->
    <div class="space-y-6">
      <div>
        <label for="full-name" class="block text-sm font-bold mb-2 booking-form-label">Full Name</label>
        <input type="text" id="full-name" name="full-name" required class="w-full p-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-fiery-terracotta focus:border-transparent transition bg-gray-50">
      </div>
      <div>
        <label for="email" class="block text-sm font-bold mb-2 booking-form-label">Email Address</label>
        <input type="email" id="email" name="email" required class="w-full p-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-fiery-terracotta focus:border-transparent transition bg-gray-50">
      </div>
      <div>
        <label for="phone" class="block text-sm font-bold mb-2 booking-form-label">Phone Number</label>
        <input type="tel" id="phone" name="phone" placeholder="(123) 456-7890" required class="w-full p-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-fiery-terracotta focus:border-transparent transition bg-gray-50">
      </div>
    </div>

    <!-- Hidden Inputs for Form Submission -->
    <input type="hidden" id="selected-date" name="selected-date">
    <input type="hidden" id="selected-time" name="selected-time">

    <!-- Submit Button (Full Width) -->
    <div class="md:col-span-2 text-center pt-4">
      <button type="submit" class="w-full md:w-auto text-white font-bold py-4 px-16 rounded-lg transition-transform transform hover:scale-105 shadow-xl text-lg booking-form-button">
        Book My Appointment
      </button>
    </div>
  </form>
  <noscript>
    <p class="text-center text-red-500 mt-4">JavaScript is required to use this booking form.</p>
  </noscript>
</div>

<!-- MODALS (Date & Time Pickers) -->
<div id="date-modal" class="fixed inset-0 bg-black bg-opacity-50 flex justify-center items-center hidden" role="dialog" aria-modal="true" aria-labelledby="date-modal-title">
  <div class="bg-white p-4 rounded-lg shadow-2xl">
    <h4 id="date-modal-title" class="sr-only">Choose a date</h4>
    <div id="calendar-container"></div>
  </div>
</div>

<div id="time-modal" class="fixed inset-0 bg-black bg-opacity-50 flex justify-center items-center hidden" role="dialog" aria-modal="true" aria-labelledby="time-modal-title">
  <div class="bg-white p-8 rounded-lg shadow-2xl w-full max-w-md">
    <h4 id="time-modal-title" class="text-xl font-bold text-center mb-6 time-modal-h4">Choose a Time</h4>
    <div id="time-slots-container" class="grid grid-cols-3 gap-4"></div>
  </div>
</div>

<!-- EXTERNAL LIBRARIES -->
<link href="https://cdn.jsdelivr.net/npm/vanilla-calendar-pro/build/vanilla-calendar.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/vanilla-calendar-pro/build/vanilla-calendar.min.js" defer></script>

<script src="../scripts/booking.js"></script>
