---
// src/components/DoorAnimation.astro
---
<div id="door-animation-container" class="fixed top-0 left-0 w-full h-full z-50">
    <div id="door-backdrop" class="door-backdrop">
        <div id="door" class="door">
            <!-- The door itself is now the glass pane -->
        </div>
    </div>
    <div id="click-to-enter" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-white text-2xl font-bold opacity-100">
        Click to Enter
    </div>
</div>

<style>
    .door-backdrop {
        perspective: 1500px;
        transform-style: preserve-3d;
        /* Create a black frame with a transparent center that aligns with the door */
        background:
            linear-gradient(to right, black calc(50vw - 25.3125vh), transparent calc(50vw - 25.3125vh), transparent calc(50vw + 25.3125vh), black calc(50vw + 25.3125vh)),
            linear-gradient(to bottom, black 5%, transparent 5%, transparent 95%, black 95%);
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        /* Fly-through animation properties */
        transform: scale(1);
        opacity: 1;
        transition: transform 1s ease-in, opacity 1s ease-in;
    }

    .door {
        height: 90%;
        aspect-ratio: 9 / 16;
        position: relative;
        transform-style: preserve-3d;
        transform-origin: left center;
        transition: transform 1s cubic-bezier(0.8, 0, 0.2, 1);
        
        /* Full Frosted Glass Effect */
        background-color: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px); /* A stronger blur for a better effect */
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 0 80px rgba(0,0,0,0.4);
    }
</style>
