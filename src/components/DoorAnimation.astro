---
// src/components/DoorAnimation.astro
---
<div id="door-animation-container" class="fixed top-0 left-0 w-full h-full z-50">
    <div id="door-backdrop" class="door-backdrop">
        <div id="door" class="door-container">
            <div id="door-left" class="door-half">
                <div class="handle"></div>
            </div>
            <div id="door-right" class="door-half">
                <div class="handle"></div>
            </div>
        </div>
    </div>
</div>

<style>
    .door-backdrop {
        perspective: 1500px;
        transform-style: preserve-3d;
        background: transparent;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        transform: scale(1);
        opacity: 1;
        transition: opacity 1s ease-in 0.5s;
    }

    .door-container {
        height: 90%;
        aspect-ratio: 9 / 16;
        display: flex;
        box-shadow: 0 0 100px rgba(0,0,0,0.7), 0 0 0 100vmax rgba(0,0,0,1);
    }

    .door-half {
        position: relative; /* For handle positioning */
        width: 50%;
        height: 100%;
        transition: transform 1.2s cubic-bezier(0.8, 0, 0.2, 1);
        
        /* Improved Frosted Glass Effect */
        background-color: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: inset 0 0 15px rgba(255, 255, 255, 0.1); /* Adds depth */
    }

    #door-right {
        border-left: 1px solid rgba(255, 255, 255, 0.1);
    }

    .handle {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 12px;
        height: 30%;
        background-color: rgba(0, 0, 0, 0.7);
        border: 1px solid rgba(0, 0, 0, 0.9);
        border-radius: 6px;
        box-shadow: 0 0 5px rgba(0, 0, 0, 0.5);
    }

    #door-left .handle {
        right: 20px;
    }

    #door-right .handle {
        left: 20px;
    }
</style>
