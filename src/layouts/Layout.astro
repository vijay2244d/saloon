---
import Footer from '../components/Footer.astro';
import SidePanels from '../components/SidePanels.astro';
import Door from '../components/Door.astro';
import Dock from '../components/Dock.jsx';
import ThemeToggle from '../components/ThemeToggle.jsx';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;

// Use Astro's built in BASE_URL (this will be '/saloon/' on Github Pages)
const baseUrl = import.meta.env.BASE_URL;

// Fix the home page check so it matches the base URL or root
const isHomePage = Astro.url.pathname === baseUrl || Astro.url.pathname === '/';

// Prefix all the navigation links with the base URL
const navLinks = [
  { href: baseUrl, label: "Home" }, // becomes '/saloon/'
  { href: `${baseUrl}about`, label: "About" }, // becomes '/saloon/about'
  { href: `${baseUrl}services`, label: "Services" },
  { href: `${baseUrl}booking`, label: "Booking" },
  { href: `${baseUrl}reviews`, label: "Reviews" },
  { href: `${baseUrl}offers`, label: "Offers" },
];

const dockItems = navLinks.map(link => ({
    // Prefix the icons with the base URL too
    icon: `${baseUrl}${link.label.toLowerCase()}.svg`,
    label: link.label,
    href: link.href
}));

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Prefix the favicon link with the base URL -->
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
    <style>
      .theme-toggle-container {
        position: fixed;
        top: 1.5rem;
        right: 1.5rem;
        z-index: 1000;
      }
    </style>
  </head>
  <body class:list={[
    "bg-ivory text-gunmetal dark:bg-gunmetal dark:text-ivory",
    { "home": isHomePage },
  ]}>
    <div class="theme-toggle-container">
      <ThemeToggle client:load />
    </div>
    <SidePanels />
    <Door />
    <main>
        <slot />
    </main>
    <Footer />
    <div class="fixed bottom-4 sm:bottom-6 md:bottom-8 left-1/2 -translate-x-1/2 z-50">
        <Dock items={dockItems} client:load />
    </div>
  </body>
</html>
