---
import Layout from '../layouts/Layout.astro';

const offers = [
  {
    title: 'First-Time Client Special',
    description: 'New to The Smart Salon? Get 20% off your first AI-powered haircut and styling service. Book now and experience the future of hairdressing!',
  },
  {
    title: 'Refer a Friend',
    description: 'Love your new look? Share the love and get $25 off your next appointment for every friend you refer. Your friend will also get 15% off their first service.',
  },
  {
    title: 'Seasonal Style Package',
    description: 'Get ready for the new season with our Seasonal Style Package. Includes an AI-powered haircut and styling, a robotic color and treatment, and a custom 3D-printed hair accessory. Book now and save 15%!',
  },
];
---

<Layout title="Offers - The Smart Salon">
    <section class="py-20">
        <div class="container mx-auto px-4">
            <h1 class="text-5xl font-bold text-center mb-12">Special Offers</h1>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                {offers.map(offer => (
                    <div class="bg-white rounded-lg shadow-lg p-8 text-center">
                        <h3 class="text-2xl font-bold mb-4">{offer.title}</h3>
                        <p class="text-gray-700 mb-6">{offer.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>
</Layout>
