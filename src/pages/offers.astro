---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Gift from '../components/Gift.astro';
---

<Layout title="Special Offers - The Smart Salon">
  <Header />
  <main class="relative overflow-hidden bg-ivory">
    <div class="container mx-auto p-8 relative z-10">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold" style="color: var(--gunmetal);">Special Offers</h1>
        <p class="text-lg mt-4 text-gray-600">Exclusive deals, just for you!</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        
        <div class="bg-white rounded-lg shadow-xl overflow-hidden transform hover:-translate-y-2 transition-transform duration-300">
          <div class="p-6">
            <h3 class="text-2xl font-bold mb-2" style="color: var(--gunmetal);">20% Off Your First Visit</h3>
            <p class="text-gray-700 mb-4">New to The Smart Salon? We'd love to welcome you with a special discount on your first service.</p>
            <Gift />
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-xl overflow-hidden transform hover:-translate-y-2 transition-transform duration-300">
          <div class="p-6">
            <h3 class="text-2xl font-bold mb-2" style="color: var(--gunmetal);">Refer a Friend, Get $25 Off</h3>
            <p class="text-gray-700 mb-4">Share the love! When you refer a friend, you'll both receive $25 off your next service.</p>
            <Gift />
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-xl overflow-hidden transform hover:-translate-y-2 transition-transform duration-300">
          <div class="p-6">
            <h3 class="text-2xl font-bold mb-2" style="color: var(--gunmetal);">Complimentary Deep Conditioning</h3>
            <p class="text-gray-700 mb-4">Book any color service and receive a complimentary deep conditioning treatment to keep your hair healthy and vibrant.</p>
            <Gift />
          </div>
        </div>

      </div>
    </div>
  </main>
</Layout>
