---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="About - The Smart Salon">
  <Header />
  <main>
    <section class="py-16 md:py-24 bg-white">
      <div class="container mx-auto text-center px-4">
        <h2 class="text-3xl font-bold mb-4" style="color: var(--gunmetal);">About The Smart Salon</h2>
        <p class="max-w-3xl mx-auto text-lg" style="color: var(--gunmetal);">
          Founded in 2024, The Smart Salon is a fusion of cutting-edge technology and timeless style. We believe in a personalized approach to hair care, using smart diagnostics and expert artistry to craft the perfect look for you. Our mission is to provide an unparalleled salon experience, from the moment you walk through our digital door.
        </p>
      </div>
    </section>
  </main>
</Layout>
