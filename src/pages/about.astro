---
import Layout from '../layouts/Layout.astro';

const teamMembers = [
  {
    name: 'Alexandre Dubois',
    role: 'Creative Director',
    bio: 'Alexandre is the visionary behind The Smart Salon, with over 15 years of experience in avant-garde hair styling and a passion for blending artistry with technology. His work has been featured in international fashion magazines, and he is a two-time recipient of the prestigious Global Hairdresser of the Year award.',
    image: '/team/alexandre.jpg'
  },
  {
    name: 'Isabella Rossi',
    role: 'Master Colorist & AI Specialist',
    bio: 'Isabella is a world-renowned colorist, known for her ability to create breathtakingly vibrant and nuanced hair colors. She has pioneered the use of our AI-powered color analysis system, ensuring that every client receives a perfectly customized and flattering shade.',
    image: '/team/isabella.jpg'
  },
  {
    name: 'Kenji Tanaka',
    role: 'Lead Stylist & Robotic Precision Expert',
    bio: 'Kenji brings a unique blend of traditional Japanese haircutting techniques and modern robotic precision to his craft. He is the lead operator of our automated styling systems, guaranteeing a flawless and consistent result with every cut.',
    image: '/team/kenji.jpg'
  },
    {
    name: 'Sofia Rodriguez',
    role: 'Client Experience Manager & Tech Integrationist',
    bio: 'Sofia is the heart of our client experience, ensuring that every visit to The Smart Salon is seamless, personalized, and unforgettable. She is also responsible for integrating our various technologies, from the AI-powered consultations to the automated appointment system.',
    image: '/team/sofia.jpg'
  }
];

---

<Layout title="About Us - The Smart Salon">
  <section class="py-20">
    <div class="container mx-auto px-4">
      <h1 class="text-5xl font-bold text-center mb-12">Meet the Future of Hairdressing</h1>
      <p class="text-xl text-center max-w-3xl mx-auto mb-20">At The Smart Salon, we believe that the perfect hairstyle is a blend of artistry and science. Our team of world-class stylists and technicians are not only masters of their craft, but also pioneers in the use of artificial intelligence and robotics to create a truly personalized and revolutionary salon experience.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
        {teamMembers.map(member => (
          <div class="bg-white rounded-lg shadow-lg overflow-hidden transform hover:scale-105 transition-transform duration-300">
            <img src={member.image} alt={member.name} class="w-full h-80 object-cover">
            <div class="p-6">
              <h3 class="text-2xl font-bold mb-2">{member.name}</h3>
              <p class="text-lg text-[var(--fiery-terracotta)] font-semibold mb-4">{member.role}</p>
              <p class="text-gray-700">{member.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
