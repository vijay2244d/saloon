---

<Layout title="Reviews | The Smart Salon">
  <main>
    <section id="reviews" class="content-section">
      <h2>What Our Clients Say</h2>
      <div class="review-grid">
        {reviews.map(review => (
          <div class="review-card">
            <p>"{review.text}"</p>
            <h4>- {review.name}</h4>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  .content-section {
    padding: 4rem 1rem;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .content-section h2 {
    margin-bottom: 2rem;
  }

  .review-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .review-card {
    background: var(--white);
    padding: 2rem;
    border-radius: 16px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.05);
    text-align: left;
  }

  .review-card p {
    font-style: italic;
    color: var(--text-secondary);
  }

  .review-card h4 {
    text-align: right;
    color: var(--primary);
    margin-top: 1rem;
  }
</style>
