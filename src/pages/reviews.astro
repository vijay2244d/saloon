---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { reviews } from '../data/reviews.js';
---

<Layout title="Customer Reviews - The Smart Salon">
  <Header />
  <main class="container mx-auto p-8">
    <h1 class="text-4xl font-bold text-center mb-12" style="color: var(--gunmetal);">What Our Clients Say</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      {reviews.map(review => (
        <div class="bg-white p-6 rounded-lg shadow-lg transform hover:scale-105 transition-transform duration-300">
          <div class="flex items-center mb-4">
            <div>
              <h3 class="text-xl font-bold" style="color: var(--gunmetal);">{review.name}</h3>
              <div class="text-yellow-400">{'★'.repeat(review.rating)}</div>
            </div>
          </div>
          <p class="text-gray-600">"{review.text}"</p>
        </div>
      ))}

    </div>
  </main>
</Layout>
