---
import Layout from '../layouts/Layout.astro';
import StatusIndicator from '../components/StatusIndicator.jsx';
import SaloonStatus from '../components/SaloonStatus.jsx';
import Curtain from '../components/Curtain.astro';
---

<Layout title="The Smart Salon | Home">
  <Curtain />
  <main>
    <div class="hero-container">
      <div class="status-indicator-wrapper">
        <StatusIndicator client:only="react" />
      </div>
      <div class="saloon-status-wrapper">
        <SaloonStatus client:only="react" />
      </div>

      <div class="hero-content">
        <h1>The Smart Salon</h1>
        <p>Cutting-edge styles, real-time availability.</p>
        <a href="/services" class="button">Our Services</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .hero-container {
    text-align: center;
    padding: 6rem 1rem 4rem;
    position: relative;
  }

  .status-indicator-wrapper {
    position: absolute;
    top: 1.5rem;
    right: 2rem;
  }

  .saloon-status-wrapper {
    position: absolute;
    top: 5rem;
    right: 2rem;
  }

  .hero-content p {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .content-section {
    padding: 4rem 0;
    text-align: center;
  }

  @media (max-width: 768px) {
    .hero-container {
      padding: 4rem 1rem 2rem;
    }
    .status-indicator-wrapper {
      top: 1rem;
      right: 1rem;
    }
    .saloon-status-wrapper {
      top: 4rem;
      right: 1rem;
    }
    .content-section {
      padding: 3rem 0;
    }
  }
</style>
