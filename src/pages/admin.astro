---
import Layout from '../layouts/Layout.astro';
import AdminControls from '../components/AdminControls.jsx';
---

<Layout title="Admin Panel | The Smart Salon">
  <main class="admin-main">
    <div class="admin-container">
      <h1>Admin Panel</h1>
      <p>Control the salon's status in real-time.</p>
      <AdminControls client:load />
    </div>
  </main>
</Layout>

<style>
  .admin-main {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 8rem);
    padding: 2rem;
  }
  .admin-container {
    background-color: var(--white);
    padding: 3rem;
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.1);
    text-align: center;
    max-width: 500px;
    width: 100%;
  }
  h1 {
    margin-bottom: 1rem;
  }
  p {
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }
</style>
