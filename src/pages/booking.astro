---
import Layout from '../layouts/Layout.astro';
import PhoneNumber from '../components/PhoneNumber.astro';

const { searchParams } = Astro.url;
const selectedService = searchParams.get('service');

const services = [
  {
    title: 'Haircuts & Styling',
    description: "Our expert stylists create personalized haircuts and styles to suit your individual features and lifestyle. We offer everything from classic cuts to the latest trends.",
    icon: '/services/hair-care.svg'
  },
  {
    title: 'Hair Coloring',
    description: "Transform your look with our professional hair coloring services. We use high-quality products to achieve stunning results, from subtle highlights to bold new colors.",
    icon: '/services/specialty.svg'
  },
  {
    title: 'Hair Treatments',
    description: "Revitalize your hair with our nourishing treatments. We offer a range of services to repair damage, add moisture, and restore shine, leaving your hair healthy and vibrant.",
    icon: '/services/hair-care.svg'
  },
  {
    title: 'Manicures & Pedicures',
    description: "Indulge in our luxurious manicures and pedicures. Our skilled technicians will leave your hands and feet looking and feeling their best, with a wide range of colors and finishes to choose from.",
    icon: '/services/nail-body.svg'
  },
  {
    title: 'Facials & Skincare',
    description: "Rejuvenate your skin with our customized facials and skincare treatments. We use premium products and advanced techniques to address your specific skin concerns and reveal a radiant complexion.",
    icon: '/services/skin-face.svg'
  },
    {
    title: 'Waxing & Hair Removal',
    description: "Achieve smooth, silky skin with our professional waxing and hair removal services. Our experienced estheticians provide a comfortable and effective experience, leaving you with long-lasting results.",
    icon: '/services/specialty.svg'
  }
];
---

<Layout title="Booking - The Smart Salon">
    <section class="py-20">
        <div class="container mx-auto px-4">
            <h1 class="text-5xl font-bold text-center mb-12">Book Your Appointment</h1>
            <p class="text-xl text-center max-w-3xl mx-auto mb-12">Ready to experience the future of hairdressing? Book your appointment today and let us help you redefine your look.</p>

            <form id="booking-form" class="max-w-xl mx-auto bg-white/10 backdrop-blur-sm p-8 rounded-lg shadow-xl border border-white/20">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="md:col-span-2">
                        <label for="service" class="block text-sm font-medium text-[var(--gunmetal)] mb-2">Service</label>
                        <select id="service" name="service" class="w-full bg-[var(--ivory)] border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-2 focus:ring-[var(--fiery-terracotta)] text-[var(--gunmetal)]">
                            {services.map(service => (
                                <option value={service.title} selected={service.title === selectedService}>{service.title}</option>
                            ))}
                        </select>
                    </div>

                    <div>
                        <label for="name" class="block text-sm font-medium text-[var(--gunmetal)] mb-2">Full Name</label>
                        <input type="text" id="name" name="name" class="w-full bg-[var(--ivory)] border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-2 focus:ring-[var(--fiery-terracotta)] text-[var(--gunmetal)]" required>
                    </div>

                    <div>
                        <label for="email" class="block text-sm font-medium text-[var(--gunmetal)] mb-2">Email Address</label>
                        <input type="email" id="email" name="email" class="w-full bg-[var(--ivory)] border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-2 focus:ring-[var(--fiery-terracotta)] text-[var(--gunmetal)]" required>
                    </div>

                    <div>
                        <label for="phone" class="block text-sm font-medium text-[var(--gunmetal)] mb-2">Phone Number</label>
                        <input type="tel" id="phone" name="phone" class="w-full bg-[var(--ivory)] border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-2 focus:ring-[var(--fiery-terracotta)] text-[var(--gunmetal)]" required>
                    </div>

                     <div>
                        <label for="date" class="block text-sm font-medium text-[var(--gunmetal)] mb-2">Preferred Date</label>
                        <input type="date" id="date" name="date" class="w-full bg-[var(--ivory)] border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-2 focus:ring-[var(--fiery-terracotta)] text-[var(--gunmetal)]" required>
                    </div>

                     <div class="md:col-span-2">
                        <label for="time" class="block text-sm font-medium text-[var(--gunmetal)] mb-2">Preferred Time</label>
                        <input type="time" id="time" name="time" class="w-full bg-[var(--ivory)] border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-2 focus:ring-[var(--fiery-terracotta)] text-[var(--gunmetal)]" required>
                    </div>
                </div>

                <div class="mt-8 text-center">
                    <button type="submit" class="bg-[var(--fiery-terracotta)] text-white font-bold py-3 px-8 rounded-full hover:bg-opacity-90 transition-all transform hover:scale-105 shadow-lg">
                        Book Now
                    </button>
                </div>
                <div id="status-message" class="mt-4 text-center"></div>
            </form>

            <div class="text-center mt-12">
                 <p class="text-lg mb-2">Or call us to book:</p>
                 <PhoneNumber />
            </div>

        </div>
    </section>
    <script>
        const form = document.getElementById('booking-form');
        const statusMessage = document.getElementById('status-message');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());

            statusMessage.textContent = 'Sending...';
            statusMessage.style.color = 'var(--gunmetal)';

            try {
                const response = await fetch('/api/send-email', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(data),
                });

                if (response.ok) {
                    statusMessage.textContent = 'Booking request sent successfully!';
                    statusMessage.style.color = 'green';
                    form.reset();
                } else {
                    const errorData = await response.json();
                    statusMessage.textContent = `Error: ${errorData.error || 'Something went wrong'}`;
                    statusMessage.style.color = 'red';
                }
            } catch (error) {
                console.error('Error submitting form:', error);
                statusMessage.textContent = 'An unexpected error occurred.';
                statusMessage.style.color = 'red';
            }
        });
    </script>
</Layout>
