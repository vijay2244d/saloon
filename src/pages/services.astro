---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HairAnimation from '../components/HairAnimation.astro';
---

<Layout title="Services - The Smart Salon">
  <Header />
  <HairAnimation />
  <main>
    <section class="py-16 md:py-24" style="background-color: var(--ivory);">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-center mb-12" style="color: var(--gunmetal);">Our Services</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Service Card 1 -->
          <div class="bg-white p-8 rounded-lg shadow-md text-center">
            <h3 class="text-2xl font-bold mb-4" style="color: var(--fiery-terracotta);">Smart Haircut</h3>
            <p style="color: var(--gunmetal);">A precision cut enhanced with our AI-powered style analysis to perfectly match your features.</p>
          </div>
          <!-- Service Card 2 -->
          <div class="bg-white p-8 rounded-lg shadow-md text-center">
            <h3 class="text-2xl font-bold mb-4" style="color: var(--fiery-terracotta);">Chroma Color</h3>
            <p style="color: var(--gunmetal);">Vibrant, long-lasting color formulated with our smart color-matching technology.</p>
          </div>
          <!-- Service Card 3 -->
          <div class="bg-white p-8 rounded-lg shadow-md text-center">
            <h3 class="text-2xl font-bold mb-4" style="color: var(--fiery-terracotta);">Revive Treatment</h3>
            <p style="color: var(--gunmetal);">A deep conditioning treatment that uses smart sensors to target and repair damaged hair.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
