---
import Layout from '../layouts/Layout.astro';
import HairFalling from '../components/HairFalling.astro';

const services = [
  {
    title: 'HairCare & Styling',
    description: "Our AI-powered hair analysis helps you find the perfect cut, color, and style. We combine the latest trends with timeless techniques to create a look that's uniquely you, ensuring you leave with healthy, beautiful hair.",
    icon: '/services/hair-care.svg'
  },
  {
    title: 'Specialty & Modern Services',
    description: "Step into the future with AI-powered consultations, robotic precision treatments, and virtual reality style previews. We offer a truly personalized and futuristic salon experience you won't find anywhere else.",
    icon: '/services/specialty.svg'
  },
  {
    title: 'Nail & Body Care',
    description: "Indulge in our luxurious nail and body treatments. From chip-resistant gel manicures to robotic massages and automated body wraps, we use cutting-edge technology and the finest products to leave you feeling refreshed and rejuvenated.",
    icon: '/services/nail-body.svg'
  },
  {
    title: 'Skin & Face Treatments',
    description: "Reveal your natural glow with our advanced skin treatments. Using state-of-the-art skin analysis, we customize facials, peels, and microdermabrasion to address your specific needs, helping you achieve a healthy, radiant complexion.",
    icon: '/services/skin-face.svg'
  },
];
---

<Layout title="Services - The Smart Salon">
    <HairFalling />
    <section class="py-20">
        <div class="container mx-auto px-4">
            <h1 class="text-5xl font-bold text-center mb-12">Our Services</h1>
            <p class="text-xl text-center max-w-3xl mx-auto mb-20">At The Smart Salon, we offer a range of revolutionary services that blend the artistry of our expert stylists with the precision of cutting-edge technology. Whether you're looking for a bold new look or a subtle refresh, we have the tools and expertise to make it happen.</p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                {services.map(service => (
                    <a href={`/booking?service=${encodeURIComponent(service.title)}`} class="block bg-white rounded-lg shadow-lg overflow-hidden transform hover:scale-105 transition-transform duration-300">
                        <div class="p-6">
                            <div class="flex items-center mb-4">
                                <img src={service.icon} alt={service.title} class="w-12 h-12 mr-4" />
                                <h3 class="text-2xl font-bold">{service.title}</h3>
                            </div>
                            <p class="text-gray-700">{service.description}</p>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </section>
</Layout>
