---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HairFalling from '../components/HairFalling.astro';
---

<Layout title="Our Services - The Smart Salon">
  <Header />
  <main class="relative overflow-hidden bg-ivory">
    <HairFalling />
    <div class="container mx-auto p-8 relative z-10">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold" style="color: var(--gunmetal);">Our Services</h1>
        <p class="text-lg mt-4 text-gray-600">Precision cuts, vibrant color, and rejuvenating treatments, all tailored to you.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        
        <div class="bg-white rounded-lg shadow-xl overflow-hidden transform hover:-translate-y-2 transition-transform duration-300">
          <img src="https://images.unsplash.com/photo-1595054995348-19717135f375?q=80&w=1887&auto=format&fit=crop" alt="Haircut and Styling" class="w-full h-48 object-cover">
          <div class="p-6">
            <h3 class="text-2xl font-bold mb-2" style="color: var(--gunmetal);">Precision Haircuts</h3>
            <p class="text-gray-700 mb-4">Whether you want a timeless classic or a modern, edgy look, our stylists will craft a haircut that perfectly suits your features and lifestyle.</p>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-xl overflow-hidden transform hover:-translate-y-2 transition-transform duration-300">
          <img src="https://images.unsplash.com/photo-1619451429983-5330a50155a4?q=80&w=1887&auto=format&fit=crop" alt="Hair Coloring" class="w-full h-48 object-cover">
          <div class="p-6">
            <h3 class="text-2xl font-bold mb-2" style="color: var(--gunmetal);">Expert Coloring</h3>
            <p class="text-gray-700 mb-4">From subtle highlights to bold, transformative color, our colorists use premium products to achieve stunning, long-lasting results while maintaining hair health.</p>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-xl overflow-hidden transform hover:-translate-y-2 transition-transform duration-300">
          <img src="https://images.unsplash.com/photo-1542856453-339b88a5310a?q=80&w=1887&auto=format&fit=crop" alt="Special Treatments" class="w-full h-48 object-cover">
          <div class="p-6">
            <h3 class="text-2xl font-bold mb-2" style="color: var(--gunmetal);">Luxe Treatments</h3>
            <p class="text-gray-700 mb-4">Revitalize your hair with our range of deep conditioning, keratin, and scalp treatments designed to restore shine, strength, and vitality.</p>
          </div>
        </div>

      </div>
    </div>
  </main>
</Layout>
