---
import Layout from '../layouts/Layout.astro';
import Login from '../components/Login.jsx';
---

<Layout title="Admin Login | The Smart Salon">
  <main class="login-main">
    <div class="login-container">
      <h1>Admin Login</h1>
      <p>Please sign in to manage the salon status.</p>
      <Login client:load />
    </div>
  </main>
</Layout>

<style>
  .login-main {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 8rem);
    padding: 2rem;
  }
  .login-container {
    background-color: var(--white);
    padding: 3rem;
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.1);
    text-align: center;
    max-width: 450px;
    width: 100%;
  }
  h1 {
    margin-bottom: 1rem;
  }
  p {
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }
</style>
